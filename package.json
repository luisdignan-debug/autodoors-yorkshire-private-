{
  "name": "checkatrade-enquiry-manager",
  "version": "1.0.0",
  "description": "Compliant Checkatrade enquiry tracker and draft-reply MVP for a UK garage door business.",
  "main": "src/index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/index.js app",
    "dev": "node src/index.js app",
    "build": "node --check src/index.js && node --check src/admin/appServer.js && node --check src/financialCalculations.js && node --check src/supplierInvoiceCalculations.js && node --check src/customerInvoices.js && node --check src/schedule.js && node --check src/messageProvider.js",
    "db:migrate": "node src/index.js db-migrate",
    "test": "node --test tests/*.test.js",
    "test-mode": "node src/index.js test-mode",
    "dry-run": "node src/index.js test-mode --dry-run",
    "checkatrade": "node src/index.js checkatrade",
    "checkatrade:login": "node src/index.js checkatrade-login",
    "checkatrade:dry-run": "node src/index.js checkatrade --dry-run",
    "checkatrade:pull": "node src/index.js checkatrade --live",
    "checkatrade:debug": "node src/index.js checkatrade --dry-run --selector-debug",
    "import-csv": "node src/index.js import-csv",
    "imap-check": "node src/index.js imap-check",
    "sync:email": "node src/index.js sync-email --live",
    "sync:email:dry-run": "node src/index.js sync-email --dry-run",
    "manual-review": "node src/index.js manual-review",
    "test-siteground-fixtures": "node src/index.js test-mode --provider siteground-fixtures",
    "test-webhook-local": "node src/index.js test-webhook-local",
    "webhook": "node src/index.js webhook"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "imapflow": "^1.0.181",
    "mailparser": "^3.7.2",
    "nodemailer": "^8.0.10",
    "pg": "^8.21.0",
    "playwright": "^1.54.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED"
}
